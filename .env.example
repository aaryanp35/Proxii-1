# Google Maps API key (required for zip scoring)
MAPS_API_KEY=your_google_maps_api_key

# Supabase — server-side (required for job applications)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase — browser/Vite (required for resume uploads)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Proximity cache merge radius in meters (default 1500)
PROXIMITY_THRESHOLD_METERS=1500
